# === Polymarket Wallet ===
# Generate an EOA wallet:
#   python -c "from eth_account import Account; a=Account.create(); print(f'Address: {a.address}\nKey: {a.key.hex()}')"
# Or use MetaMask and export the private key.
POLYGON_WALLET_PRIVATE_KEY=0x_your_private_key_here
EOA_ADDRESS=0x_your_eoa_address_here

# === Workspace ===
# Directory for ledger, logs, traces (auto-created on first run)
WORKSPACE_DIR=workspace

# === Polygon RPC (optional, defaults to public node) ===
# POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# === Dashboard (optional) ===
# Initial deposit amount for P&L calculation baseline (default: 100)
# INITIAL_DEPOSIT=100

# === Withdraw (optional, for scripts/withdraw.py) ===
# WITHDRAW_DESTINATION=0x_your_destination_address
